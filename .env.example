MONGO_URI=mongodb://localhost:27017/consent-management
JWT_SECRET=your_super_secret_jwt_key_here
BASE_URL=http://localhost:3000
PORT=3000

# ── Email ────────────────────────────────────────────────
# Set to "false" to disable sending — links are printed to console instead (useful for local dev)
EMAIL_ENABLED=true

# Provider: "sendgrid" or "smtp"
EMAIL_PROVIDER=sendgrid
FROM_EMAIL=noreply@yourdomain.com

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# SMTP (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.yourmailserver.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
