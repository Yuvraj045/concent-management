<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Consent Decision — Consent Manager</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .card { background: #fff; padding: 2.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); width: 100%; max-width: 480px; text-align: center; }
    h1 { font-size: 1.5rem; margin-bottom: 1rem; }
    .description { color: #555; margin-bottom: 1.5rem; line-height: 1.6; }
    .email { font-weight: 600; color: #333; }
    .actions { display: flex; gap: 1rem; justify-content: center; margin-top: 1.5rem; }
    .btn { flex: 1; padding: 0.75rem 1rem; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; font-weight: 500; }
    .btn-accept { background: #16a34a; color: #fff; }
    .btn-accept:hover { background: #15803d; }
    .btn-reject { background: #dc2626; color: #fff; }
    .btn-reject:hover { background: #b91c1c; }
    .alert { padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.875rem; }
    .alert-error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .result-icon { font-size: 3rem; margin-bottom: 1rem; }
    .result-accepted { color: #16a34a; }
    .result-rejected { color: #dc2626; }
    .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-bottom: 1.5rem; }
    .badge { display: inline-block; background: #eef2ff; color: #4f46e5; border-radius: 4px; padding: 0.25rem 0.6rem; font-size: 0.8rem; }
  </style>
</head>
<body>
  <div class="card">
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } else if (consent && consent.status !== 'pending') { %>
      <div class="result-icon <%= consent.status === 'accepted' ? 'result-accepted' : 'result-rejected' %>">
        <%= consent.status === 'accepted' ? '✓' : '✗' %>
      </div>
      <h1>Consent <%= consent.status === 'accepted' ? 'Accepted' : 'Rejected' %></h1>
      <p class="description">
        You have <strong><%= consent.status %></strong> consent for <strong><%= banner.name %></strong>.<br>
        <span class="email"><%= email %></span>
      </p>
      <p style="color:#888;font-size:0.85rem;margin-top:1rem;">You can close this window.</p>
    <% } else { %>
      <h1><%= banner ? banner.name : 'Consent Request' %></h1>
      <% if (banner && banner.description) { %>
        <p class="description"><%= banner.description %></p>
      <% } %>
      <% if (banner && banner.subscriptionTypes && banner.subscriptionTypes.length > 0) { %>
        <div class="tags">
          <% banner.subscriptionTypes.forEach(type => { %>
            <span class="badge"><%= type %></span>
          <% }) %>
        </div>
      <% } %>
      <p class="description">
        Responding as: <span class="email"><%= email %></span>
      </p>
      <p class="description">Do you consent to the above?</p>
      <div class="actions">
        <form method="POST" action="/consent/submit/<%= token %>">
          <input type="hidden" name="decision" value="accepted">
          <button type="submit" class="btn btn-accept">Accept</button>
        </form>
        <form method="POST" action="/consent/submit/<%= token %>">
          <input type="hidden" name="decision" value="rejected">
          <button type="submit" class="btn btn-reject">Reject</button>
        </form>
      </div>
    <% } %>
  </div>
</body>
</html>
