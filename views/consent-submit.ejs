<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Preferences — Consent Manager</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 1rem; }
    .card { background: #fff; padding: 2.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); width: 100%; max-width: 500px; }
    h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .label { font-size: 0.75rem; font-weight: 600; color: #4f46e5; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
    .description { color: #555; margin-bottom: 1.25rem; line-height: 1.6; font-size: 0.9rem; }
    .email-line { font-size: 0.875rem; color: #666; margin-bottom: 1.5rem; }
    .email-line strong { color: #333; }
    .alert { padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.875rem; }
    .alert-error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .result-icon { font-size: 3rem; margin-bottom: 1rem; text-align: center; }
    .result-accepted { color: #16a34a; }
    .result-rejected { color: #dc2626; }

    /* Subscription toggle table */
    .sub-table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
    .sub-table th { text-align: left; padding: 0.5rem 0.75rem; font-size: 0.8rem; font-weight: 600; color: #555; background: #f8fafc; border-bottom: 2px solid #e2e8f0; }
    .sub-table td { padding: 0.75rem; border-bottom: 1px solid #f0f0f0; font-size: 0.9rem; vertical-align: middle; }
    .sub-table td:last-child { text-align: right; }
    .sub-name { font-weight: 500; color: #333; }
    .sub-desc { font-size: 0.8rem; color: #888; }

    /* Toggle switch */
    .toggle { position: relative; display: inline-block; width: 48px; height: 26px; }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background: #ddd; border-radius: 26px; transition: 0.2s; }
    .slider:before { position: absolute; content: ""; height: 20px; width: 20px; left: 3px; bottom: 3px; background: #fff; border-radius: 50%; transition: 0.2s; }
    input:checked + .slider { background: #4f46e5; }
    input:checked + .slider:before { transform: translateX(22px); }
    .toggle-label { font-size: 0.75rem; color: #888; margin-top: 0.25rem; text-align: right; }

    .btn-submit { width: 100%; padding: 0.75rem; background: #4f46e5; color: #fff; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; font-weight: 500; }
    .btn-submit:hover { background: #4338ca; }
    .divider { border: none; border-top: 1px solid #f0f0f0; margin: 1.5rem 0; }

    /* Result view sub list */
    .result-subs { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    .result-subs td { padding: 0.5rem 0.75rem; font-size: 0.875rem; border-bottom: 1px solid #f0f0f0; }
    .result-subs td:last-child { text-align: right; font-weight: 500; }
    .on { color: #16a34a; }
    .off { color: #dc2626; }
    .hint { text-align: center; color: #aaa; font-size: 0.8rem; margin-top: 1rem; }
  </style>
</head>
<body>
  <div class="card">
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>

    <% } else if (consent && consent.status === 'submitted') { %>
      <!-- Submitted result view -->
      <div class="label">Preference Center</div>
      <h1><%= banner.name %></h1>
      <p class="description">Your preferences have been saved.</p>
      <p class="email-line">Submitted as: <strong><%= email %></strong></p>
      <hr class="divider">
      <table class="result-subs">
        <% consent.subscriptions.forEach(sub => { %>
          <tr>
            <td><%= sub.name %></td>
            <td class="<%= sub.enabled ? 'on' : 'off' %>">
              <%= sub.enabled ? '✓ Enabled' : '✗ Disabled' %>
            </td>
          </tr>
        <% }) %>
      </table>
      <p class="hint">You can close this window.</p>

    <% } else { %>
      <!-- Preference selection form -->
      <div class="label">Preference Center</div>
      <h1><%= banner ? banner.name : 'Manage Preferences' %></h1>
      <% if (banner && banner.description) { %>
        <p class="description"><%= banner.description %></p>
      <% } %>
      <p class="email-line">Managing preferences for: <strong><%= email %></strong></p>
      <hr class="divider">

      <form method="POST" action="/consent/submit/<%= token %>">
        <% if (banner && banner.subscriptionTypes && banner.subscriptionTypes.length > 0) { %>
          <table class="sub-table">
            <thead>
              <tr>
                <th>Subscription</th>
                <th style="text-align:right;">Enable</th>
              </tr>
            </thead>
            <tbody>
              <% banner.subscriptionTypes.forEach(type => { %>
                <%
                  // If there's a prior consent record, pre-fill toggle state
                  const prevSub = consent && consent.subscriptions && consent.subscriptions.find(s => s.name === type);
                  const isChecked = prevSub ? prevSub.enabled : true; // default ON
                %>
                <tr>
                  <td><span class="sub-name"><%= type %></span></td>
                  <td>
                    <label class="toggle">
                      <input type="checkbox" name="subs" value="<%= type %>" <%= isChecked ? 'checked' : '' %>>
                      <span class="slider"></span>
                    </label>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p style="color:#888;margin-bottom:1.5rem;font-size:0.9rem;">No subscriptions to configure.</p>
        <% } %>
        <button type="submit" class="btn-submit">Save Preferences</button>
      </form>
    <% } %>
  </div>
</body>
</html>
