<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Consent Manager</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f5f5f5; min-height: 100vh; }
    nav { background: #4f46e5; color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
    nav a { color: #fff; text-decoration: none; font-size: 0.875rem; }
    nav a:hover { text-decoration: underline; }
    .container { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    h1 { font-size: 1.5rem; }
    .btn { padding: 0.5rem 1rem; background: #4f46e5; color: #fff; border: none; border-radius: 4px; font-size: 0.875rem; cursor: pointer; text-decoration: none; display: inline-block; }
    .btn:hover { background: #4338ca; }
    .btn-sm { padding: 0.375rem 0.75rem; font-size: 0.8rem; }
    .btn-outline { background: transparent; color: #4f46e5; border: 1px solid #4f46e5; }
    .btn-outline:hover { background: #eef2ff; }
    .card { background: #fff; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); margin-bottom: 1.25rem; overflow: hidden; }
    .card-header { padding: 1.25rem 1.5rem; display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid #f0f0f0; }
    .card-title { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.25rem; }
    .card-desc { color: #666; font-size: 0.875rem; }
    .slug-badge { display: inline-block; background: #eef2ff; color: #4f46e5; border-radius: 4px; padding: 0.125rem 0.5rem; font-size: 0.75rem; font-family: monospace; margin-top: 0.375rem; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 0.5rem 1.5rem; font-size: 0.8rem; border-bottom: 1px solid #f0f0f0; }
    th { background: #f8fafc; font-weight: 600; color: #555; }
    td:last-child { color: #888; }
    .empty { text-align: center; color: #888; padding: 3rem 0; }
    .no-subs { color: #aaa; font-size: 0.8rem; font-style: italic; padding: 0.75rem 1.5rem; }
  </style>
</head>
<body>
  <nav>
    <strong>Consent Manager</strong>
    <div style="display:flex;gap:1rem;">
      <span style="font-size:0.875rem;opacity:0.85"><%= user.email %></span>
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <div class="container">
    <div class="header">
      <h1>Your Preference Centers</h1>
      <a href="/banners/new" class="btn">+ New Preference Center</a>
    </div>

    <% if (banners.length === 0) { %>
      <div class="empty">
        <p>No preference centers yet. Create your first one!</p>
      </div>
    <% } else { %>
      <% banners.forEach(banner => { %>
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title"><%= banner.name %></div>
              <% if (banner.description) { %><div class="card-desc"><%= banner.description %></div><% } %>
              <span class="slug-badge">/b/<%= banner.slug %></span>
            </div>
            <a href="/banners/<%= banner._id %>" class="btn btn-sm btn-outline">View</a>
          </div>
          <% if (banner.subscriptionTypes && banner.subscriptionTypes.length > 0) { %>
            <table>
              <thead>
                <tr>
                  <th>Subscription Type</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% banner.subscriptionTypes.forEach(type => { %>
                  <tr>
                    <td><%= type %></td>
                    <td>Active</td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else { %>
            <div class="no-subs">No subscription types defined.</div>
          <% } %>
        </div>
      <% }) %>
    <% } %>
  </div>
</body>
</html>
