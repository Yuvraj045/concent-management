<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Consent Manager</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f5f5f5; min-height: 100vh; }
    nav { background: #4f46e5; color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
    nav a { color: #fff; text-decoration: none; font-size: 0.875rem; }
    nav a:hover { text-decoration: underline; }
    .container { max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    h1 { font-size: 1.5rem; }
    .btn { padding: 0.5rem 1rem; background: #4f46e5; color: #fff; border: none; border-radius: 4px; font-size: 0.875rem; cursor: pointer; text-decoration: none; display: inline-block; }
    .btn:hover { background: #4338ca; }
    .banner-card { background: #fff; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); padding: 1.25rem 1.5rem; margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center; }
    .banner-card h2 { font-size: 1.1rem; margin-bottom: 0.25rem; }
    .banner-card p { color: #666; font-size: 0.875rem; }
    .banner-actions { display: flex; gap: 0.5rem; }
    .btn-sm { padding: 0.375rem 0.75rem; font-size: 0.8rem; }
    .btn-outline { background: transparent; color: #4f46e5; border: 1px solid #4f46e5; }
    .btn-outline:hover { background: #eef2ff; }
    .empty { text-align: center; color: #888; padding: 3rem 0; }
    .slug-badge { display: inline-block; background: #eef2ff; color: #4f46e5; border-radius: 4px; padding: 0.125rem 0.5rem; font-size: 0.75rem; font-family: monospace; margin-top: 0.25rem; }
  </style>
</head>
<body>
  <nav>
    <strong>Consent Manager</strong>
    <div style="display:flex;gap:1rem;">
      <span style="font-size:0.875rem;opacity:0.85"><%= user.email %></span>
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <div class="container">
    <div class="header">
      <h1>Your Banners</h1>
      <a href="/banners/new" class="btn">+ New Banner</a>
    </div>

    <% if (banners.length === 0) { %>
      <div class="empty">
        <p>No banners yet. Create your first one!</p>
      </div>
    <% } else { %>
      <% banners.forEach(banner => { %>
        <div class="banner-card">
          <div>
            <h2><%= banner.name %></h2>
            <% if (banner.description) { %><p><%= banner.description %></p><% } %>
            <span class="slug-badge">/b/<%= banner.slug %></span>
          </div>
          <div class="banner-actions">
            <a href="/banners/<%= banner._id %>" class="btn btn-sm btn-outline">View</a>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</body>
</html>
