<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= banner.name %> — Consent Request</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .card { background: #fff; padding: 2.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); width: 100%; max-width: 480px; }
    h1 { font-size: 1.5rem; margin-bottom: 0.75rem; }
    .description { color: #555; margin-bottom: 1.5rem; line-height: 1.6; }
    .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
    .badge { display: inline-block; background: #eef2ff; color: #4f46e5; border-radius: 4px; padding: 0.25rem 0.6rem; font-size: 0.8rem; }
    .form-group { margin-bottom: 1rem; }
    label { display: block; margin-bottom: 0.25rem; font-size: 0.875rem; font-weight: 500; }
    input { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; }
    input:focus { outline: none; border-color: #4f46e5; }
    .btn { width: 100%; padding: 0.625rem; background: #4f46e5; color: #fff; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
    .btn:hover { background: #4338ca; }
    .alert { padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.875rem; }
    .alert-error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .alert-success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
    .divider { border: none; border-top: 1px solid #f0f0f0; margin: 1.5rem 0; }
  </style>
</head>
<body>
  <div class="card">
    <h1><%= banner.name %></h1>
    <% if (banner.description) { %>
      <p class="description"><%= banner.description %></p>
    <% } %>
    <% if (banner.subscriptionTypes && banner.subscriptionTypes.length > 0) { %>
      <div class="tags">
        <% banner.subscriptionTypes.forEach(type => { %>
          <span class="badge"><%= type %></span>
        <% }) %>
      </div>
    <% } %>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } else { %>
      <hr class="divider">
      <form method="POST" action="/consent/request">
        <input type="hidden" name="bannerId" value="<%= banner._id %>">
        <div class="form-group">
          <label for="email">Enter your email to receive a consent verification link</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email">
        </div>
        <button type="submit" class="btn">Send Consent Request</button>
      </form>
    <% } %>
  </div>
</body>
</html>
