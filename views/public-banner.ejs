<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= banner.name %> — Preference Center</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .card { background: #fff; padding: 2.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); width: 100%; max-width: 500px; }
    h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .label { font-size: 0.75rem; font-weight: 600; color: #4f46e5; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
    .description { color: #555; margin-bottom: 1.5rem; line-height: 1.6; font-size: 0.9rem; }
    .sub-table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
    .sub-table th, .sub-table td { text-align: left; padding: 0.5rem 0.75rem; font-size: 0.85rem; border-bottom: 1px solid #f0f0f0; }
    .sub-table th { background: #f8fafc; font-weight: 600; color: #555; }
    .sub-table td:last-child { color: #16a34a; font-weight: 500; }
    .form-group { margin-bottom: 1rem; }
    label { display: block; margin-bottom: 0.25rem; font-size: 0.875rem; font-weight: 500; }
    input[type="email"] { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; }
    input[type="email"]:focus { outline: none; border-color: #4f46e5; }
    .btn { width: 100%; padding: 0.625rem; background: #4f46e5; color: #fff; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
    .btn:hover { background: #4338ca; }
    .alert { padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.875rem; }
    .alert-error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .alert-success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
    .divider { border: none; border-top: 1px solid #f0f0f0; margin: 1.5rem 0; }
  </style>
</head>
<body>
  <div class="card">
    <div class="label">Preference Center</div>
    <h1><%= banner.name %></h1>
    <% if (banner.description) { %>
      <p class="description"><%= banner.description %></p>
    <% } %>

    <% if (banner.subscriptionTypes && banner.subscriptionTypes.length > 0) { %>
      <table class="sub-table">
        <thead>
          <tr>
            <th>Subscription</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% banner.subscriptionTypes.forEach(type => { %>
            <tr>
              <td><%= type %></td>
              <td>Available</td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } else { %>
      <hr class="divider">
      <form method="POST" action="/consent/request">
        <input type="hidden" name="bannerId" value="<%= banner._id %>">
        <div class="form-group">
          <label for="email">Enter your email to manage your preferences</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email">
        </div>
        <button type="submit" class="btn">Send Preference Link</button>
      </form>
    <% } %>
  </div>
</body>
</html>
