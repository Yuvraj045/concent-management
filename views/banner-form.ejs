<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Preference Center — Consent Manager</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f5f5f5; min-height: 100vh; }
    nav { background: #4f46e5; color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
    nav a { color: #fff; text-decoration: none; font-size: 0.875rem; }
    nav a:hover { text-decoration: underline; }
    .container { max-width: 600px; margin: 2rem auto; padding: 0 1rem; }
    .card { background: #fff; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    h1 { margin-bottom: 1.5rem; font-size: 1.5rem; }
    .form-group { margin-bottom: 1.25rem; }
    label { display: block; margin-bottom: 0.25rem; font-size: 0.875rem; font-weight: 500; }
    input[type="text"], textarea { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; font-family: inherit; }
    input[type="text"]:focus, textarea:focus { outline: none; border-color: #4f46e5; }
    textarea { resize: vertical; min-height: 80px; }
    .hint { font-size: 0.75rem; color: #888; margin-top: 0.25rem; }
    .btn { padding: 0.625rem 1.25rem; background: #4f46e5; color: #fff; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
    .btn:hover { background: #4338ca; }
    .btn-cancel { background: transparent; color: #666; border: 1px solid #ddd; margin-left: 0.5rem; }
    .btn-cancel:hover { background: #f5f5f5; }
    .btn-add { background: transparent; color: #4f46e5; border: 1px solid #4f46e5; font-size: 0.875rem; padding: 0.4rem 0.875rem; border-radius: 4px; cursor: pointer; }
    .btn-add:hover { background: #eef2ff; }
    .alert-error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.875rem; }
    .actions { display: flex; align-items: center; }
    .sub-list { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 0.5rem; }
    .sub-item { display: flex; gap: 0.5rem; align-items: center; }
    .sub-item input { flex: 1; }
    .btn-remove { background: transparent; border: none; color: #dc2626; font-size: 1.25rem; cursor: pointer; line-height: 1; padding: 0 0.25rem; }
    .btn-remove:hover { color: #b91c1c; }
  </style>
</head>
<body>
  <nav>
    <strong>Consent Manager</strong>
    <div style="display:flex;gap:1rem;">
      <span style="font-size:0.875rem;opacity:0.85"><%= user.email %></span>
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <div class="container">
    <div class="card">
      <h1>Create New Preference Center</h1>
      <% if (error) { %><div class="alert-error"><%= error %></div><% } %>
      <form method="POST" action="/banners/new">
        <div class="form-group">
          <label for="name">Preference Center Name</label>
          <input type="text" id="name" name="name" required placeholder="e.g. Marketing Communications">
        </div>
        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" placeholder="Describe what consent is being requested for..."></textarea>
        </div>
        <div class="form-group">
          <label>Subscription Types</label>
          <div class="sub-list" id="sub-list">
            <div class="sub-item">
              <input type="text" name="subscriptionTypes[]" placeholder="e.g. Newsletter" required>
              <button type="button" class="btn-remove" onclick="removeSub(this)" title="Remove">×</button>
            </div>
          </div>
          <button type="button" class="btn-add" onclick="addSub()">+ Add Subscription</button>
          <p class="hint">Add each subscription type users can opt in or out of.</p>
        </div>
        <div class="actions">
          <button type="submit" class="btn">Create Preference Center</button>
          <a href="/dashboard" class="btn btn-cancel">Cancel</a>
        </div>
      </form>
    </div>
  </div>
  <script>
    function addSub() {
      const list = document.getElementById('sub-list');
      const item = document.createElement('div');
      item.className = 'sub-item';
      item.innerHTML = `
        <input type="text" name="subscriptionTypes[]" placeholder="e.g. Promotions">
        <button type="button" class="btn-remove" onclick="removeSub(this)" title="Remove">×</button>
      `;
      list.appendChild(item);
      item.querySelector('input').focus();
    }

    function removeSub(btn) {
      const list = document.getElementById('sub-list');
      if (list.children.length === 1) return; // keep at least one
      btn.closest('.sub-item').remove();
    }
  </script>
</body>
</html>
